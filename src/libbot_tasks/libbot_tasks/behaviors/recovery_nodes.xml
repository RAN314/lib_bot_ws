<?xml version="1.0" encoding="UTF-8"?>

<!--
L1恢复行为树节点定义
图书馆机器人ROS2项目 - Epic 2错误处理与恢复机制

定义L1级别快速恢复行为的BehaviorTree节点
恢复时间控制在5-10秒内
-->

<root main_tree_to_execute="RecoveryTree">
    <TreeInfo>
        <TreeName>L1快速恢复行为树</TreeName>
        <TreeVersion>1.0</TreeVersion>
        <Description>用于L1级别错误恢复的行为树定义</Description>
    </TreeInfo>

    <!-- 行为树节点库导入 -->
    <include path="../behaviors/standard_nodes.xml" />

    <!-- 定义L1恢复行为树 -->
    <BehaviorTree ID="RecoveryTree">
        <Sequence name="L1_Recovery_Sequence">

            <!-- 记录恢复开始 -->
            <Action ID="LogRecoveryStart" />

            <!-- 检查是否需要L1恢复 -->
            <Condition ID="NeedL1Recovery" />

            <!-- 选择恢复类型 -->
            <ReactiveFallback name="Recovery_Type_Selector">

                <!-- RFID扫描失败恢复 -->
                <Sequence name="RFID_Rescan_Recovery">
                    <Condition ID="IsRFIDFailure" />
                    <Action ID="RetryRFIDScan" />
                </Sequence>

                <!-- 定位丢失恢复 -->
                <Sequence name="Relocalization_Recovery">
                    <Condition ID="IsLocalizationLost" />
                    <Action ID="RelocalizeRobot" />
                </Sequence>

                <!-- 目标不可达恢复 -->
                <Sequence name="Target_Redefinition_Recovery">
                    <Condition ID="IsTargetUnreachable" />
                    <Action ID="RedefineTarget" />
                </Sequence>

                <!-- 无匹配恢复策略，升级到L2 -->
                <Action ID="EscalateToL2" />

            </ReactiveFallback>

            <!-- 记录恢复结果 -->
            <Action ID="LogRecoveryResult" />
        </Sequence>
    </BehaviorTree>

    <!-- RFID重新扫描节点 -->
    <BehaviorTree ID="RetryRFIDScan">
        <RetryUntilSuccessful num_attempts="3">
            <Timeout duration="10">
                <AsyncAction ID="PerformRFIDRescan" />
            </Timeout>
        </RetryUntilSuccessful>
    </BehaviorTree>

    <!-- 重新定位节点 -->
    <BehaviorTree ID="RelocalizeRobot">
        <Timeout duration="10">
            <Action ID="PerformRotationLocalization" />
        </Timeout>
    </BehaviorTree>

    <!-- 目标重定义节点 -->
    <BehaviorTree ID="RedefineTarget">
        <Timeout duration="8">
            <Action ID="FindAlternativeTarget" />
        </Timeout>
    </BehaviorTree>

    <!-- 条件节点定义 -->

    <!-- 检查是否需要L1恢复 -->
    <BehaviorTree ID="NeedL1Recovery">
        <Script code="return ctx.needs_l1_recovery();" />
    </BehaviorTree>

    <!-- 检查是否为RFID失败 -->
    <BehaviorTree ID="IsRFIDFailure">
        <Script code="return ctx.get_error_type() == 'rfid_failure';" />
    </BehaviorTree>

    <!-- 检查是否定位丢失 -->
    <BehaviorTree ID="IsLocalizationLost">
        <Script code="return ctx.get_error_type() == 'localization_lost';" />
    </BehaviorTree>

    <!-- 检查目标是否不可达 -->
    <BehaviorTree ID="IsTargetUnreachable">
        <Script code="return ctx.get_error_type() == 'target_unreachable';" />
    </BehaviorTree>

    <!-- 动作节点定义 -->

    <!-- 执行RFID重新扫描 -->
    <BehaviorTree ID="PerformRFIDRescan">
        <AsyncAction ID="L1RecoveryBehaviors::retry_rfid_scan">
            <InputPort name="book_id" value="ctx.target_book_id" />
            <InputPort name="position" value="ctx.target_position" />
        </AsyncAction>
    </BehaviorTree>

    <!-- 执行重新定位 -->
    <BehaviorTree ID="PerformRotationLocalization">
        <Action ID="L1RecoveryBehaviors::relocalize_robot" />
    </BehaviorTree>

    <!-- 查找替代目标 -->
    <BehaviorTree ID="FindAlternativeTarget">
        <AsyncAction ID="L1RecoveryBehaviors::redefine_target">
            <InputPort name="original_goal" value="ctx.current_goal" />
        </AsyncAction>
    </BehaviorTree>

    <!-- 记录恢复开始 -->
    <BehaviorTree ID="LogRecoveryStart">
        <Script code="
            ctx.get_logger().info('L1恢复开始: ' + ctx.get_error_description());
            ctx.recovery_start_time = ctx.get_clock().now();
            return BT.Status.SUCCESS;
        " />
    </BehaviorTree>

    <!-- 记录恢复结果 -->
    <BehaviorTree ID="LogRecoveryResult">
        <Script code="
            auto end_time = ctx.get_clock().now();
            auto duration = end_time - ctx.recovery_start_time;
            ctx.get_logger().info('L1恢复完成，耗时: ' + std::to_string(duration.seconds()) + '秒');
            return BT.Status.SUCCESS;
        " />
    </BehaviorTree>

    <!-- 升级到L2恢复 -->
    <BehaviorTree ID="EscalateToL2">
        <Script code="
            ctx.get_logger().warn('L1恢复失败，升级到L2恢复');
            ctx.escalate_to_l2();
            return BT.Status.FAILURE;
        " />
    </BehaviorTree>

    <!-- 节点端口定义 -->
    <PortSpecs>

        <!-- L1RecoveryBehaviors::retry_rfid_scan 端口 -->
        <Node ID="L1RecoveryBehaviors::retry_rfid_scan">
            <InputPort name="book_id" type="std::string">
                目标图书ID
            </InputPort>
            <InputPort name="position" type="geometry_msgs::msg::Point">
                目标位置
            </InputPort>
            <OutputPort name="result" type="bool">
                恢复结果
            </OutputPort>
        </Node>

        <!-- L1RecoveryBehaviors::relocalize_robot 端口 -->
        <Node ID="L1RecoveryBehaviors::relocalize_robot">
            <OutputPort name="success" type="bool">
                重新定位是否成功
            </OutputPort>
        </Node>

        <!-- L1RecoveryBehaviors::redefine_target 端口 -->
        <Node ID="L1RecoveryBehaviors::redefine_target">
            <InputPort name="original_goal" type="std::map">
                原始目标信息
            </InputPort>
            <OutputPort name="alternative_goal" type="std::map">
                替代目标信息
            </OutputPort>
        </Node>

    </PortSpecs>

    <!-- 自定义节点实现提示 -->
    <ImplementationNotes>
        <!--
        这些节点需要在C++或Python中实现对应的ROS2行为树节点
        每个节点应该返回: SUCCESS(成功), FAILURE(失败), RUNNING(运行中)

        关键实现要点:
        1. Timeout节点确保恢复不会无限期运行
        2. RetryUntilSuccessful确保最多重试3次
        3. AsyncAction用于异步操作，避免阻塞行为树
        4. 所有节点都应该有适当的日志记录
        -->
    </ImplementationNotes>

</root>