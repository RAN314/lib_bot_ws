Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
  - Class: rviz_common/Time
    Name: Time

Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/TF
      Name: TF
      Value: true
      Show Arrows: false
      Show Axes: true
      Show Names: true

    - Class: rviz_default_plugins/RobotModel
      Name: RobotModel
      Value: true
      Robot Description: robot_description
      TF Prefix: ""

    - Class: rviz_default_plugins/LaserScan
      Name: LaserScan
      Value: true
      Topic: /scan
      Color: 255; 255; 255
      Size (m): 0.1

    - Class: rviz_default_plugins/Map
      Name: Map
      Value: true
      Topic: /map
      Color Scheme: map
      Draw Behind: true

    - Class: rviz_default_plugins/Path
      Name: Global Path
      Value: true
      Topic: /plan
      Color: 25; 255; 25
      Width: 0.3

    - Class: rviz_default_plugins/MarkerArray
      Name: RFID Visualization
      Value: true
      Topic: /rfid_visualization
      Namespaces:
        rfid_tags: true
        rfid_labels: true
        rfid_ranges: true

    - Class: rviz_default_plugins/Marker
      Name: RFID Detection Areas
      Value: true
      Topic: /rfid_detection_markers

Window Geometry:
  Displays:
    collapsed: false
  Height: 1080
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 