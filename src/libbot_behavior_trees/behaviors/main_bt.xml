<?xml version="1.0"?>
<!-- Main Behavior Tree - Main control flow for library robot -->
<root main_tree_to_execute="MainBehaviorTree" BTCPP_format="4">

    <BehaviorTree ID="MainBehaviorTree">
        <ReactiveFallback name="Main_Control_Flow">

            <!-- 1. Error handling and recovery -->
            <Sequence name="Error_Handling">
                <SubTree ID="CheckActiveErrors" />
                <Action ID="ErrorDetectionNode" />
            </Sequence>

            <!-- 2. Task execution -->
            <Sequence name="Task_Execution">
                <Condition ID="HasPendingTasks" />
                <Action ID="PerformSystemCheck" />
            </Sequence>

            <!-- 3. System monitoring -->
            <Sequence name="System_Monitoring">
                <SubTree ID="CheckShouldMonitorSystem" />
                <Action ID="PerformSystemCheck" />
            </Sequence>

            <!-- 4. Idle state -->
            <Action ID="EnterIdleState" />

        </ReactiveFallback>
    </BehaviorTree>

    <!-- Sub-trees for specific functionality -->

    <BehaviorTree ID="CheckActiveErrors">
        <Condition ID="ErrorDetectionNode" />
    </BehaviorTree>

    <BehaviorTree ID="CheckShouldMonitorSystem">
        <Condition ID="IsNavigationStuck" />
    </BehaviorTree>

</root>